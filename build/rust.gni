# Rust procedural macro template
template("rust_proc_macro") {
  assert(defined(invoker.crate_name), "crate_name must be defined")
  assert(defined(invoker.crate_root), "crate_root must be defined")
  
  rust_static_library(target_name) {
    forward_variables_from(invoker, "*")
    
    if (!defined(rustc_flags)) {
      rustc_flags = []
    }
    rustc_flags += [ "--crate-type=proc-macro" ]
  }
}

# Cargo workspace template
template("cargo_workspace") {
  assert(defined(invoker.manifest_path), "manifest_path must be defined")
  
  action(target_name) {
    forward_variables_from(invoker, [
      "deps",
      "visibility",
      "testonly",
    ])
    
    manifest_path = invoker.manifest_path
    
    if (defined(invoker.package)) {
      package = invoker.package
    } else {
      package = ""
    }
    
    # Output directory
    output_dir = "$target_out_dir/cargo"
    outputs = [ "$output_dir/.stamp" ]
    
    # Build script
    script = "//build/scripts/build_cargo.py"
    
    # Arguments
    args = [
      "--manifest-path", rebase_path(manifest_path, root_build_dir),
      "--output-dir", rebase_path(output_dir, root_build_dir),
      "--target", target_cpu,
    ]
    
    if (package != "") {
      args += [ "--package", package ]
    }
    
    if (is_debug) {
      args += [ "--debug" ]
    } else {
      args += [ "--release" ]
    }
    
    if (defined(invoker.features)) {
      foreach(feature, invoker.features) {
        args += [ "--feature", feature ]
      }
    }
  }
}

