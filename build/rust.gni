# Rust build rules for RustixOS
# Professional Rust build system integration

import("//build/config/rustix_config.gni")

# Rust static library template
template("rust_static_library") {
  assert(defined(invoker.crate_name), "crate_name must be defined")
  assert(defined(invoker.crate_root), "crate_root must be defined")
  
  action(target_name) {
    forward_variables_from(invoker, [
      "deps",
      "public_deps",
      "data_deps",
      "sources",
      "inputs",
      "visibility",
      "testonly",
    ])
    
    crate_name = invoker.crate_name
    crate_root = invoker.crate_root
    
    if (defined(invoker.edition)) {
      edition = invoker.edition
    } else {
      edition = rust_edition
    }
    
    if (defined(invoker.features)) {
      features = invoker.features
    } else {
      features = []
    }
    
    if (defined(invoker.cfg)) {
      cfg = invoker.cfg
    } else {
      cfg = []
    }
    
    # Output file
    output_name = crate_name
    if (defined(invoker.output_name)) {
      output_name = invoker.output_name
    }
    
    output_file = "$target_out_dir/lib$output_name.rlib"
    outputs = [ output_file ]
    
    # Build script
    script = "//build/scripts/build_rust.py"
    
    # Arguments
    args = [
      "--crate-name", crate_name,
      "--crate-root", rebase_path(crate_root, root_build_dir),
      "--output", rebase_path(output_file, root_build_dir),
      "--edition", edition,
      "--target", target_cpu,
      "--crate-type", "staticlib",
    ]
    
    if (is_debug) {
      args += [ "--debug" ]
    } else {
      args += [ "--release" ]
    }
    
    foreach(feature, features) {
      args += [ "--feature", feature ]
    }
    
    foreach(config, cfg) {
      args += [ "--cfg", config ]
    }
    
    if (defined(invoker.rustc_flags)) {
      foreach(flag, invoker.rustc_flags) {
        args += [ "--rustc-flag", flag ]
      }
    }
    
    # Dependencies
    if (defined(deps)) {
      foreach(dep, deps) {
        args += [ "--dep", dep ]
      }
    }
    
    # Environment variables
    if (defined(invoker.rustc_env)) {
      foreach(env_var, invoker.rustc_env) {
        args += [ "--env", env_var ]
      }
    }
  }
}

